############## Agent配置 ##############
# 领队Agent配置，其它Agent同理
# 你的LLM供应商的API地址
LEADER_BASE_URL=
# 你的API密钥
LEADER_API_KEY=
# 你要使用的模型的名称
LEADER_MODEL=

# 侦察Agent配置
RECON_BASE_URL=
RECON_API_KEY=
RECON_MODEL=

# 分析Agent配置
ANALYSIS_BASE_URL=
ANALYSIS_API_KEY=
ANALYSIS_MODEL=

# 进攻Agent配置
ATTACK_BASE_URL=
ATTACK_API_KEY=
ATTACK_MODEL=

# 报告Agent配置
REPORT_BASE_URL=
REPORT_API_KEY=
REPORT_MODEL=

############## 网络空间测绘配置 ##############
# 奇安信Hunter（可选）
HUNTER_API_KEY=你的Hunter密钥

# tavily配置（可选）
# 你的tavily MCP地址
TAVILY_MCP_URL=
# 你的tavily API密钥
TAVILY_API_KEY=

# 数据库配置
# PostgreSQL数据库连接URL
DATABASE_URL=

# Kali Linux主机地址
KALI_HOST=
# kali ssh 私钥(base64编码)
KALI_SSH_KEY=

# Langsmith配置
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# 你的Langsmith API密钥
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT="default"

############## Web应用配置 ##############
# JWT密钥，建议修改为随机字符串
JWT_SECRET=redagi-jwt-secret-key-2024-change-me
# 默认用户名，建议修改
DEFAULT_USER=admin
# 默认密码，建议修改
DEFAULT_PASS=admin123
